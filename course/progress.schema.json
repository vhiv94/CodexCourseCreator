{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "course-progress",
  "title": "Course progress",
  "description": "Learner and workflow routing state; lives at course/progress.yaml or course/progress.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["last_completed"],
  "properties": {
    "last_completed": {
      "description": "Most recently completed lesson, or null before any lesson is finished.",
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/lessonRef" }
      ]
    },
    "next_target": {
      "description": "Legacy-compatible explicit next lesson. Prefer current_target for adaptive flows, but keep this for existing linear courses.",
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/lessonRef" }
      ]
    },
    "current_target": {
      "description": "Current adaptive target for the next step of work.",
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/currentTarget" }
      ]
    },
    "generation_mode": {
      "$ref": "#/$defs/generationMode"
    },
    "recent_assessment": {
      "type": "object",
      "additionalProperties": false,
      "description": "Lightweight assessment context used for pre-structure planning, prechapter routing, replanning, and batching.",
      "required": ["kind", "summary"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["entry", "prestructure", "prechapter", "checkpoint", "chapter_end", "module_end", "manual"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "review": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "deepen": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "recommended_next_step": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "notes": {
      "type": "string",
      "description": "Optional freeform context: blockers, pacing, constraints, or routing notes."
    }
  },
  "$defs": {
    "generationMode": {
      "type": "string",
      "enum": ["lesson_first", "full_spine", "module_batch", "chapter_batch", "adaptive"]
    },
    "moduleRef": {
      "type": "string",
      "pattern": "^M[1-9][0-9]*$"
    },
    "chapterRef": {
      "type": "string",
      "pattern": "^Ch[1-9][0-9]*$"
    },
    "lessonRef": {
      "type": "string",
      "pattern": "^Ch[1-9][0-9]*/L[1-9][0-9]*$"
    },
    "currentTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "ref"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["lesson", "chapter", "module", "assessment", "replan"]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "lesson" } },
            "required": ["type"]
          },
          "then": {
            "properties": { "ref": { "$ref": "#/$defs/lessonRef" } }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "chapter" } },
            "required": ["type"]
          },
          "then": {
            "properties": { "ref": { "$ref": "#/$defs/chapterRef" } }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "module" } },
            "required": ["type"]
          },
          "then": {
            "properties": { "ref": { "$ref": "#/$defs/moduleRef" } }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "assessment" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "ref": {
                "type": "string",
                "pattern": "^(entry|prestructure|prechapter:Ch[1-9][0-9]*|module:M[1-9][0-9]*|chapter:Ch[1-9][0-9]*|lesson:Ch[1-9][0-9]*/L[1-9][0-9]*)$"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "replan" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "ref": {
                "type": "string",
                "pattern": "^(course|module:M[1-9][0-9]*|chapter:Ch[1-9][0-9]*)$"
              }
            }
          }
        }
      ]
    }
  }
}
